# =============================================================================
# .gitignore — RISKLABUSTA
# =============================================================================

# Entornos virtuales locales
venv/
.venv/
env/
ENV/
lib/
lib64/
bin/
include/
share/

# Caché de compilación de Python (Bytecode)
**/__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Bases de datos y persistencia SQLite local
*.db
*.sqlite
*.sqlite3
backend/risklab.db

# Configuración y secretos del entorno (Claves de API, etc.)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env
!backend/.env.example

# Archivos del sistema operativo y del IDE
.DS_Store
.DS_Store?
**/Thumbs.db
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Modelos entrenados y archivos pesados (se generan localmente)
*.joblib
*.pkl
backend/trading_model.joblib

# Temporales de R y Python, datos locales e informes de auditoria scratch
.Rhistory
.RData
.Ruserdata
scratch/
data/
